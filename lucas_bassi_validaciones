def ingresar_dias_vencimiento():
    """ Ingresar los dias para el vencimiento del medicamento y validar que sean correctos """

    dias = int(input("Ingrese los días para el vencimiento del medicamento: "))

    while True:
        # Validar los días para el vencimiento del medicamento
        if validar_numero_positivo(dias):
            print(f"Días para el vencimiento {dias} ingresados correctamente.")
            break
        else:
            print(f"Días para el vencimiento {dias} no es valido")
            dias = int(input("Ingrese los días para el vencimiento del medicamento: "))
    return dias



    

