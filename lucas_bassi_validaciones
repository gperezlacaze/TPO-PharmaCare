def validar_nombre_medicamento(medicamento):
    '''Validar que el nombre del medicamento no este vacio.'''

  # Verificar si el nombre del medicamento esta vacio
    if medicamento.strip() == "":
        print("El nombre del medicamento no puede estar vacío.")
        return False
    return True



def validar_codigo_medicamento(codigo):
    """ Validar que el medicamento contenga entre 4 y 10 caracteres(no pueden ser espacios o simbolos). """

    cantidad_caracteres = len(codigo)

# Validar que el codigo tenga entre 4 y 10 caracteres
    if 4 <= cantidad_caracteres <= 10:
        simbolos = "@,.=+-_$!¿?¡#%&/()"

        # Recorrer cada caracter
        for i in range(cantidad_caracteres):
             # Verificar si el caracter es un espacio o un simbolo
             if codigo[i].strip() == "" or codigo[i] in simbolos:
                 # Caracter no valido
                 return False
        return True
                 
    else: 
        print("Codigo no valido, debe tener entre 4 y 10 caracteres")
        return False



def validar_laboratorio_fabricante(laboratorio):
    """ Validar que el nombre del laboratorio solo contenga letras"""

# Validar que el nombre del laboratorio no este vacio
    if laboratorio.strip() != "":
         # Verificar si solo contiene letras
         if laboratorio.isalpha():
             print("El nombre es correcto")
             return True
         else:
             print("El nombre del laboratorio es incorrecto")
             return False
    else:
        print("El nombre del laboratorio no puede estar vacío")
        return False
    

    
def validar_precio(precio):
    """ Validar que un numero sea positivo para dias, precio y stock """

    if precio >= 0:
        return True
    else:
        print("El número no puede ser negativo")
        return False
    


def validar_numero_positivo(numero):
    """ Validar que un numero sea positivo para dias y stock """

    if numero > 0:
        return True
    else:
        print("El número no puede ser negativo")
        return False

      

def validar_cobertura(cobertura):
    """ Validar que la cobertura sea: 'Con cobertura' o 'Sin cobertura' """
  
    if cobertura.capitalize() == "Con cobertura" or cobertura.capitalize() == "Sin cobertura":
        return True
    else:
        print("La cobertura no es válida")
        return False







