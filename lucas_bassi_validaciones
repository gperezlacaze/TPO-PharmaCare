def ingresar_medicamento():
    """ Ingresar medicamento y validar su nombre. """

    medicamento = input("Ingrese el nombre del medicamento: ").capitalize()

    # Validar el nombre del medicamento
    while True:
      if validar_nombre_medicamento(medicamento):
        print(f"medicamento {medicamento} ingresado correctamente.")
        break
      else:
         print("medicamento ingresado no es válido. Intente nuevamente.")
         medicamento = input("Ingrese el nombre del medicamento: ").capitalize()
    return medicamento
       


def ingresar_codigo():
    """ Ingresar codigo del medicamento y validr su formato """

    codigo = input("Ingresa codigo del medicamento:").upper()

    while True:
      if validar_codigo_medicamento(codigo):
         print(f"Codigo {codigo} ingresado correctamente.")
         break
      else:
         print(f"Codigo {codigo} no valido")
         codigo = input("Ingresa codigo del medicamento:").upper()
    return codigo



def ingresar_laboratorio():
    """ ingresar el nombre del laboratorio y validar su formato"""

    laboratorio = str(input("Ingresa el nombre del laboratorio: "))

    while True:
        # Validar el nombre del laboratorio
        if validar_laboratorio_fabricante(laboratorio):
            print(f"El laboratorio {laboratorio} es valido")
            break
        else:
            print(f"El laboratorio {laboratorio} noes valido")
            laboratorio = str(input("Ingresa el nombre del laboratorio: "))
    return laboratorio



def ingresar_precio():
    """ Ingresar el precio del medicamento y verificar que sea correcto"""

    precio = float(input("ingresa el precio del medicamento: "))

    while True:
        # Validar el precio del medicamento
        if validar_precio(precio):
             print(f"Precio {precio} ingresado correctamente.")
             break 
        else:
             print(f"Precio {precio} no es valido")
             precio = float(input("ingresa el precio del medicamento: "))
    return precio
          


def ingresar_stock():
    """ Ingresar el stock del medicamento y validar que sea correcto   """

    stock = int(input("ingresa el stock del medicamento: "))

    while True:
        # Validar el stock del medicamento
        if validar_numero_positivo(stock):
            print(f"Stock {stock} ingresado correctamente.")
            break
        else:
            print(f"Stock {stock} no es valido")
            stock = int(input("ingresa el stock del medicamento: "))
    return stock



def ingresar_cobertura():
    """ Ingresar la cobertura del medicamento y validar que sea correcta """

    cobertura = str(input("Ingrese la cobertura del medicamento (Con cobertura/Sin cobertura): "))

    while True:
        # Validar la cobertura del medicamento
        if validar_cobertura(cobertura):
            print(f"Cobertura {cobertura} ingresada correctamente.")
            break
        else:
            print(f"Cobertura {cobertura} no es valida")
            cobertura = input("Ingrese la cobertura del medicamento (Con cobertura/Sin cobertura): ")
